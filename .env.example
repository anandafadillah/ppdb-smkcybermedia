# ─────────────────────────────────────────────
# PPDB SMK Cyber Media Jakarta — Environment
# Salin file ini menjadi .env lalu isi nilainya
# ─────────────────────────────────────────────

# ── Aplikasi ──────────────────────────────────
APP_NAME="PPDB SMK Cyber Media"
APP_ENV=local              # local | staging | production
APP_KEY=                   # Di-generate otomatis: php artisan key:generate
APP_DEBUG=true             # Set false di production
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug            # debug | info | warning | error

# ── Database (MySQL) ──────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ppdb_smkcybermedia
DB_USERNAME=root
DB_PASSWORD=

# ── Session ───────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120       # Menit
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Broadcasting / Queue / Cache ──────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Mail (opsional, tidak wajib untuk PPDB) ───
MAIL_MAILER=log            # Ganti smtp di production
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="ppdb@smkcybermedia.sch.id"
MAIL_FROM_NAME="${APP_NAME}"

# ── Redis (opsional) ──────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Storage berkas peserta ────────────────────
# File upload peserta disimpan di storage/app/private/berkas/{peserta_id}/
# Pastikan php artisan storage:link sudah dijalankan
FILESYSTEM_DISK=local

# ── Vite ──────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
